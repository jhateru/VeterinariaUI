<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="society.controller.principales.NuevoDuenoController">
    <Label text="Agregar Nuevo Dueño" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1b1c1c;" />
    
    <GridPane vgap="10" hgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="text-field" />
        
        <Label text="Apellidos:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtApellidos" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="DNI/ID:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtDni" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        
        <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <ComboBox fx:id="cmbEstado" GridPane.columnIndex="1" GridPane.rowIndex="5" maxWidth="Infinity" />
        
        <Label text="Mascotas:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
        <TextField fx:id="txtMascotas" promptText="Ej: Luna, Toby" GridPane.columnIndex="1" GridPane.rowIndex="6" />
    </GridPane>
    
    <Region VBox.vgrow="ALWAYS" />
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#onCancelar" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-radius: 4; -fx-padding: 8 16; -fx-cursor: hand;" />
        <Button text="Guardar" onAction="#onGuardar" style="-fx-background-color: #006067; -fx-text-fill: white; -fx-padding: 8 16; -fx-background-radius: 4; -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>
</VBox>
