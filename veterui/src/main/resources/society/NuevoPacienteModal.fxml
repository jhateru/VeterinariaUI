<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="society.controller.principales.NuevoPacienteController">
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: white;">
        
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20; -fx-alignment: center;" prefWidth="200" prefHeight="200">
                <Label text="📸" style="-fx-font-size: 40px;" />
                <Label text="Subir foto del paciente" style="-fx-text-fill: #6e797a; -fx-font-size: 12px;" />
                <Region VBox.vgrow="ALWAYS" />
                <Label text="Formatos: JPG, PNG (Max 5MB)" style="-fx-font-size: 10px; -fx-text-fill: #1b1c1c; -fx-font-weight: bold;" />
                <Label text="Eliminar imagen" style="-fx-text-fill: #006067; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 5 0 0 0;" />
            </VBox>
            
            <VBox spacing="15" style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="🐾 Información de la Mascota" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f4c5c;" />
                
                <GridPane vgap="15" hgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="NOMBRE DE LA MASCOTA" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <TextField fx:id="txtNombre" promptText="Ej: Luna" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="ESPECIE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <ComboBox fx:id="cmbEspecie" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0;" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="RAZA" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <TextField fx:id="txtRaza" promptText="Ej: Golden Retriever" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="EDAD APROXIMADA" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <TextField fx:id="txtEdad" promptText="Ej: 2 años" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="SEXO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <HBox spacing="15">
                            <RadioButton fx:id="rbMacho" text="Macho" />
                            <RadioButton fx:id="rbHembra" text="Hembra" />
                        </HBox>
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="PESO (KG)" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                        <TextField fx:id="txtPeso" promptText="0.0" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                    </VBox>
                </GridPane>
            </VBox>
        </HBox>

        <!-- Información del Dueño -->
        <VBox spacing="15" style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT">
                <Label text="👤 Información del Dueño" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f4c5c;" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField promptText="🔍 Buscar dueño existente..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e4e2e2; -fx-background-color: #f9fafa; -fx-padding: 5 15;" prefWidth="250" />
            </HBox>
            
            <GridPane vgap="15" hgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33" />
                    <ColumnConstraints percentWidth="33" />
                    <ColumnConstraints percentWidth="34" />
                </columnConstraints>
                
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="NOMBRE COMPLETO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextField fx:id="txtDuenoNombre" promptText="Nombre y Apellidos" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                </VBox>
                
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="DNI / ID" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextField fx:id="txtDuenoDni" promptText="Ej: 12345678X" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                </VBox>
                
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="TELÉFONO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextField fx:id="txtDuenoTelefono" promptText="+34 000 000 000" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                </VBox>
                
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="CORREO ELECTRÓNICO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextField fx:id="txtDuenoEmail" promptText="correo@ejemplo.com" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                </VBox>
                
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2">
                    <Label text="DIRECCIÓN" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextField fx:id="txtDuenoDireccion" promptText="Calle, Número, Ciudad, CP" style="-fx-background-color: transparent; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- Detalles Médicos -->
        <VBox spacing="15" style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20;">
            <Label text="📋 Detalles Médicos Iniciales" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f4c5c;" />
            
            <HBox spacing="20">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="ALERGIAS CONOCIDAS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextArea fx:id="txtAlergias" promptText="Liste alergias o sensibilidades detectadas..." prefRowCount="3" style="-fx-background-color: #f9fafa; -fx-border-color: #e4e2e2; -fx-border-radius: 4;" />
                    <Label text="ℹ Dejar en blanco si no se conocen." style="-fx-font-size: 10px; -fx-text-fill: #6e797a;" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="MOTIVO DE LA PRIMERA CONSULTA" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                    <TextArea fx:id="txtMotivo" promptText="Describa el síntoma o razón de la visita..." prefRowCount="3" style="-fx-background-color: #f9fafa; -fx-border-color: #e4e2e2; -fx-border-radius: 4;" />
                </VBox>
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                <Label text="ESTADO DEL PACIENTE:" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6e797a;" />
                <ComboBox fx:id="cmbEstado" />
            </HBox>
        </VBox>
        
        <!-- Botones de Acción -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="✕ Cancelar" onAction="#onCancelar" style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 20; -fx-padding: 10 20; -fx-text-fill: #6e797a; -fx-cursor: hand;" />
            <Button text="💾 Guardar Registro" onAction="#onGuardar" style="-fx-background-color: #006067; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand;" />
        </HBox>
        
    </VBox>
</ScrollPane>
