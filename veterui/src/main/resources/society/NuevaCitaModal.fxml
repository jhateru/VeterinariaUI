<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="society.controller.principales.NuevaCitaController"
      spacing="20" style="-fx-padding: 24; -fx-background-color: #ffffff;">
    
    <Label text="Agendar Nueva Cita" styleClass="headline-md" />
    
    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Paciente:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="pacienteField" promptText="Nombre del paciente (ej. Max)" styleClass="search-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        
        <Label text="Dueño:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="duenoField" promptText="Nombre del dueño" styleClass="search-field" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Veterinario:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="veterinarioCombo" promptText="Seleccionar doctor" maxWidth="Infinity" styleClass="combo-box-filter" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        
        <Label text="Fecha:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <DatePicker fx:id="fechaPicker" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        
        <Label text="Hora:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1" alignment="CENTER_LEFT">
            <ComboBox fx:id="horaCombo" promptText="HH" styleClass="combo-box-filter" />
            <Label text=":" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="minutoCombo" promptText="MM" styleClass="combo-box-filter" />
        </HBox>
        
        <Label text="Motivo:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
        <TextField fx:id="motivoField" promptText="Motivo de consulta" styleClass="search-field" GridPane.rowIndex="5" GridPane.columnIndex="1" />
    </GridPane>
    
    <HBox alignment="CENTER_RIGHT" spacing="16">
        <Button text="Cancelar" styleClass="btn-outline" onAction="#onCancelar" />
        <Button text="Guardar Cita" styleClass="btn-primary" onAction="#onGuardar" />
    </HBox>
</VBox>
