<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.chart.*?>

<ScrollPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="society.controller.principales.RecepcionController"
      fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #fbf9f8;">
<VBox spacing="24" style="-fx-padding: 24;">
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Resumen de Recepción" styleClass="headline-lg" />
            <Label fx:id="fechaLabel" text="Cargando fecha..." style="-fx-text-fill: #6e797a;" />
        </VBox>
        <Button text="+ Nuevo Dueño" styleClass="btn-outline" onAction="#onNuevoDueno" />
        <Button text="Agendar Cita" styleClass="btn-primary" onAction="#onNuevaCita" />
    </HBox>

    <!-- Metrics -->
    <HBox spacing="16">
        <!-- Card 1 -->
        <VBox styleClass="metric-card" spacing="16" style="-fx-padding: 16;" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="📅" style="-fx-font-size: 20px;" />
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="+12% vs ayer" style="-fx-text-fill: #006067; -fx-font-weight: bold; -fx-font-size: 11px;"/>
            </HBox>
            <VBox>
                <Label text="CITAS PARA HOY" style="-fx-text-fill: #6e797a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="citasHoyValue" text="0" styleClass="metric-value"/>
            </VBox>
        </VBox>
        <!-- Card 2 -->
        <VBox styleClass="metric-card" spacing="16" style="-fx-padding: 16;" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="⏳" style="-fx-font-size: 20px;" />
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="8 min prom." style="-fx-text-fill: #3e494a; -fx-font-size: 11px;"/>
            </HBox>
            <VBox>
                <Label text="EN SALA DE ESPERA" style="-fx-text-fill: #6e797a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="esperaValue" text="0" styleClass="metric-value"/>
            </VBox>
        </VBox>
        <!-- Card 3 -->
        <VBox styleClass="metric-card" spacing="16" style="-fx-padding: 16;" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="✅" style="-fx-font-size: 20px;" />
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="85% Meta" style="-fx-text-fill: #3e494a; -fx-font-size: 11px;"/>
            </HBox>
            <VBox>
                <Label text="ATENDIDOS" style="-fx-text-fill: #6e797a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="atendidosValue" text="0" styleClass="metric-value"/>
            </VBox>
        </VBox>
        <!-- Urgent Card -->
        <VBox styleClass="card-urgent" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="⚠️" style="-fx-font-size: 24px;" />
                <VBox spacing="4">
                    <Label text="Protocolo Urgencia" styleClass="text-urgent" style="-fx-font-size: 14px;" />
                    <Label text="2 casos críticos en camino. Liberar consultorio 4." style="-fx-text-fill: #93000a; -fx-font-size: 12px;"/>
                    <Label text="VER DETALLES" style="-fx-text-fill: #93000a; -fx-font-weight: bold; -fx-underline: true; -fx-font-size: 10px; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Main Content -->
    <HBox spacing="24">
        <!-- Left Column -->
        <VBox spacing="24" HBox.hgrow="ALWAYS" prefWidth="600">
            <!-- Sala de Espera Activa -->
            <VBox styleClass="card" spacing="16">
                <HBox alignment="CENTER_LEFT">
                    <Label text="🏥 Sala de Espera Activa" styleClass="headline-md" style="-fx-font-size: 18px;" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="8">
                        <Label fx:id="caninosLabel" text="Caninos: 0" styleClass="chip"/>
                        <Label fx:id="felinosLabel" text="Felinos: 0" styleClass="chip"/>
                    </HBox>
                </HBox>
                
                <VBox fx:id="salaEsperaContainer" spacing="12">
                    <!-- Dynamic items will go here -->
                </VBox>
                
                <HBox alignment="CENTER">
                    <Label text="Ver toda la sala de espera" styleClass="link" />
                </HBox>
            </VBox>
            
            <!-- Tendencia de Ingresos -->
            <VBox styleClass="card" spacing="16">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Tendencia de Ingresos" styleClass="headline-md" style="-fx-font-size: 18px;" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="8">
                        <Button text="&lt;" styleClass="btn-outline" style="-fx-padding: 4 8;" />
                        <Button text="&gt;" styleClass="btn-outline" style="-fx-padding: 4 8;" />
                    </HBox>
                </HBox>
                <BarChart fx:id="ingresosChart" prefHeight="200" legendVisible="false">
                    <xAxis>
                        <CategoryAxis side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" visible="false" />
                    </yAxis>
                </BarChart>
            </VBox>
        </VBox>
        
        <!-- Right Column -->
        <VBox spacing="24" prefWidth="350">
            <!-- Próximas Citas -->
            <VBox styleClass="card" spacing="16">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Próximas Citas" styleClass="headline-md" style="-fx-font-size: 18px;" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="VER CALENDARIO" styleClass="link" style="-fx-font-size: 10px;"/>
                </HBox>
                <VBox fx:id="proximasCitasContainer" spacing="12">
                    <!-- Dynamic items will go here -->
                </VBox>
            </VBox>
            
            <!-- Tareas Pendientes -->
            <VBox styleClass="card" spacing="16" style="-fx-background-color: #fbf9f8;">
                <Label text="☑ Tareas Pendientes" styleClass="headline-md" style="-fx-font-size: 16px;" />
                <VBox fx:id="tareasContainer" spacing="12">
                    <!-- Dynamic items will go here -->
                </VBox>
                <Button text="+ AÑADIR TAREA" styleClass="btn-outline" maxWidth="Infinity" style="-fx-border-style: dashed; -fx-text-fill: #6e797a; -fx-border-color: #bdc9ca;" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
</ScrollPane>
