<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="society.controller.principales.PacientesController">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Gestión de Pacientes" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f4c5c;" />
            <Label text="Administra los expedientes y el estado actual de todos los animales registrados." style="-fx-text-fill: #6e797a; -fx-font-size: 13px;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Registrar Nuevo Paciente" onAction="#onNuevoPaciente" style="-fx-background-color: #006067; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <!-- Filters Section -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <!-- Especie Filters -->
        <HBox spacing="0" style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;" alignment="CENTER">
            <Label text="ESPECIE:" style="-fx-text-fill: #6e797a; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 10;" />
            <ToggleButton fx:id="btnTodo" text="Todo" onAction="#onFilterChange" selected="true" styleClass="filter-toggle" style="-fx-background-color: #006067; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 15; -fx-font-weight: bold; -fx-cursor: hand;" />
            <ToggleButton fx:id="btnPerros" text="Perros" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
            <ToggleButton fx:id="btnGatos" text="Gatos" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
            <ToggleButton fx:id="btnExoticos" text="Exóticos" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
        </HBox>

        <!-- Estado Filters -->
        <HBox spacing="0" style="-fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;" alignment="CENTER">
            <Label text="ESTADO:" style="-fx-text-fill: #6e797a; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 10;" />
            <ToggleButton fx:id="btnEnClinica" text="● En Clínica" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
            <ToggleButton fx:id="btnAlta" text="● Alta" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
            <ToggleButton fx:id="btnSeguimiento" text="● Seguimiento" onAction="#onFilterChange" styleClass="filter-toggle" style="-fx-background-color: transparent; -fx-text-fill: #6e797a; -fx-padding: 6 15; -fx-cursor: hand;" />
        </HBox>
    </HBox>

    <!-- Table Section -->
    <VBox style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
        <!-- ScrollPane Horizontal para Tabla -->
        <ScrollPane fitToHeight="true" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox minWidth="1550" VBox.vgrow="ALWAYS">
                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #e4e2e2; -fx-border-width: 0 0 1 0; -fx-background-color: #f9fafa; -fx-background-radius: 8 8 0 0;">
                    <Label text="PACIENTE" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="250" />
                    <Label text="ESPECIE / RAZA" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="200" />
                    <Label text="DUEÑO" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="200" />
                    <Label text="PESO (KG)" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="100" />
                    <Label text="ALERGIAS" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="150" />
                    <Label text="MOTIVO CONSULTA" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="200" />
                    <Label text="ÚLTIMA VISITA" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="150" />
                    <Label text="ESTADO" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="150" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="ACCIONES" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" prefWidth="100" alignment="CENTER" />
                </HBox>

                <!-- Table Body -->
                <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="pacientesContainer" spacing="0">
                        <!-- Rows dinámicos -->
                    </VBox>
                </ScrollPane>
            </VBox>
        </ScrollPane>
        
        <!-- Table Footer -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 15; -fx-border-color: #e4e2e2; -fx-border-width: 1 0 0 0; -fx-background-color: #f9fafa; -fx-background-radius: 0 0 8 8;">
            <Label fx:id="lblMostrando" text="Mostrando 0 de 0 pacientes registrados" style="-fx-text-fill: #6e797a; -fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="5">
                <Button text="&lt;" style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 4; -fx-cursor: hand;" />
                <Button text="&gt;" style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 4; -fx-cursor: hand;" />
            </HBox>
        </HBox>
    </VBox>

    <!-- Summary Cards -->
    <HBox spacing="20">
        <!-- Ocupación -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="OCUPACIÓN ACTUAL" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" />
            <HBox alignment="BOTTOM_LEFT" spacing="5">
                <Label fx:id="lblPacientesInternos" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1b1c1c;" />
                <Label text="pacientes internos" style="-fx-text-fill: #6e797a; -fx-font-size: 14px; -fx-padding: 0 0 6 0;" />
            </HBox>
            <ProgressBar fx:id="progOcupacion" progress="0.75" prefWidth="250" style="-fx-accent: #006067;" />
            <Label text="75% de capacidad hospitalaria" style="-fx-text-fill: #6e797a; -fx-font-size: 12px;" />
        </VBox>

        <!-- Consultas -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #006067; -fx-border-width: 2; -fx-border-radius: 8; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="CONSULTAS HOY" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" />
            <HBox alignment="BOTTOM_LEFT" spacing="5">
                <Label text="32" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1b1c1c;" />
                <Label text="completadas" style="-fx-text-fill: #6e797a; -fx-font-size: 14px; -fx-padding: 0 0 6 0;" />
            </HBox>
            <Label text="+12% respecto a ayer" style="-fx-text-fill: #6e797a; -fx-font-size: 12px;" />
        </VBox>

        <!-- Pendientes -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e4e2e2; -fx-border-radius: 8; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="PENDIENTES" style="-fx-font-weight: bold; -fx-text-fill: #6e797a; -fx-font-size: 12px;" />
            <HBox alignment="BOTTOM_LEFT" spacing="5">
                <Label text="5" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1b1c1c;" />
                <Label text="resultados de lab" style="-fx-text-fill: #6e797a; -fx-font-size: 14px; -fx-padding: 0 0 6 0;" />
            </HBox>
            <Label text="VER REPORTES" style="-fx-text-fill: #006067; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" />
        </VBox>
    </HBox>

</VBox>
